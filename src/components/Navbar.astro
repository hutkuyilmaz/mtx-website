---
const navLinks = [
    { href: "#home", label: "Home" },
    { href: "#solution", label: "Technology" },
    { href: "#cases", label: "Proof Matrix" },
    { href: "#contact", label: "Inquiries" },
];
---

<header
    class="fixed top-0 left-0 w-full h-20 bg-[#f6f6f5]/90 backdrop-blur-md border-b border-gray-200/50 z-50 transition-all duration-300"
>
    <div
        class="max-w-7xl mx-auto h-full px-6 flex items-center justify-between"
    >
        <a href="#home" class="flex items-center gap-2 group">
            <span
                class="w-4 h-4 rounded-full bg-[#44534b] group-hover:scale-110 transition-transform"
            ></span>
            <span
                class="font-bold tracking-wider text-xl text-[#414141] uppercase"
                >Materix</span
            >
        </a>

        <nav class="hidden md:flex items-center gap-8">
            {
                navLinks.map((link) => (
                    <a
                        href={link.href}
                        class="text-sm font-medium text-[#414141]/80 hover:text-[#44534b] transition-colors relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-[2px] after:bg-[#44534b] hover:after:w-full after:transition-all"
                    >
                        {link.label}
                    </a>
                ))
            }
            <a
                href="#contact"
                class="bg-[#44534b] text-white text-xs font-semibold uppercase tracking-wider px-5 py-2.5 rounded hover:bg-[#414141] transition-all shadow-sm"
            >
                Request Specs
            </a>
        </nav>
    </div>
</header>
