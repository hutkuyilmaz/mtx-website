---
const metrics = [
    { value: "< 1 Micron", label: "Coating Layer Thickness" },
    { value: "Under 8%", label: "Total Efficiency Loss Cap" },
    { value: "99.4%", label: "Optical Transparency Rate" },
    { value: "10+ Years", label: "Accelerated Weathering Bound" },
];
---

<div class="max-w-7xl mx-auto px-6 py-12">
    <div
        class="grid grid-cols-2 lg:grid-cols-4 gap-8 divide-y-2 lg:divide-y-0 lg:divide-x divide-[#f6f6f5]/10"
    >
        {
            metrics.map((m, idx) => (
                <div
                    class={`pt-6 lg:pt-0 ${idx > 0 ? "lg:pl-8" : ""} flex flex-col justify-center`}
                >
                    <span class="text-3xl md:text-5xl font-black tracking-tight">
                        {m.value}
                    </span>
                    <span class="text-xs font-mono uppercase tracking-widest text-[#f6f6f5]/70 mt-2">
                        {m.label}
                    </span>
                </div>
            ))
        }
    </div>
</div>
