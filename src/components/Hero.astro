---
// src/components/Hero.astro
---

<section
    class="relative min-h-[90vh] flex items-center gradient-bg py-20 overflow-hidden"
>
    <div class="absolute inset-0 bg-black/10 z-0"></div>
    <div
        class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-12 gap-12 items-center w-full"
    >
        <div class="md:col-span-7 text-white space-y-6">
            <h1
                class="text-4xl sm:text-6xl font-extrabold tracking-tight leading-tight"
            >
                Partnering for Regional <br class="hidden sm:inline" /><span
                    class="text-yellow-300">Energy Leadership</span
                >
            </h1>
            <p class="text-lg text-white/90 max-w-xl leading-relaxed">
                Yüzeyleri hidrofobik, fotokatalitik ve koruyucu özelliklerle
                dönüştüren devrimsel ince filmlerimizle sürdürülebilir bir
                geleceğe öncülük ediyoruz.
            </p>
            <ul class="space-y-3 font-medium text-white/90">
                <li class="flex items-center gap-3">
                    <span
                        class="w-5 h-5 bg-white/20 rounded-full flex items-center justify-center text-xs"
                        >✓</span
                    >
                    Güneş paneli verimliliğini %3 - %9 artırın.
                </li>
                <li class="flex items-center gap-3">
                    <span
                        class="w-5 h-5 bg-white/20 rounded-full flex items-center justify-center text-xs"
                        >✓</span
                    >
                    Temizlik ve bakım maliyetlerini %50 azaltın.
                </li>
            </ul>
            <div class="flex flex-wrap gap-4 pt-4">
                <a
                    href="#about"
                    class="px-8 py-4 bg-yellow-400 text-dark font-bold rounded-xl hover:bg-yellow-300 transition-all shadow-lg shadow-yellow-500/20"
                >
                    Explore Partnership →
                </a>
                <a
                    href="#calculator"
                    class="px-8 py-4 bg-white/10 backdrop-blur-md border border-white/20 text-white font-semibold rounded-xl hover:bg-white/20 transition-all"
                >
                    📊 Schedule Executive Briefing
                </a>
            </div>
        </div>

        <div
            id="calculator"
            class="md:col-span-5 bg-white rounded-3xl p-8 shadow-2xl space-y-6 border border-gray-100"
        >
            <div class="flex items-center gap-3 border-b border-gray-100 pb-4">
                <span class="text-2xl">📋</span>
                <h2 class="text-xl font-bold text-dark">
                    Quick Revenue Calculator
                </h2>
            </div>

            <div class="space-y-2">
                <div
                    class="flex justify-between text-sm font-semibold text-gray-600"
                >
                    <label for="power-slider">System Size (Tesis Gücü)</label>
                    <span id="power-value" class="text-primary-blue font-bold"
                        >300 MW</span
                    >
                </div>
                <input
                    type="range"
                    id="power-slider"
                    min="10"
                    max="1000"
                    value="300"
                    class="w-full h-2 bg-gray-100 rounded-lg appearance-none cursor-pointer accent-primary-blue"
                />
            </div>

            <div class="space-y-2">
                <div
                    class="flex justify-between text-sm font-semibold text-gray-600"
                >
                    <label for="production-slider"
                        >Annual Production (Yıllık Üretim)</label
                    >
                    <span
                        id="production-value"
                        class="text-primary-blue font-bold">450,000 MWh</span
                    >
                </div>
                <input
                    type="range"
                    id="production-slider"
                    min="15"
                    max="1500"
                    value="450"
                    class="w-full h-2 bg-gray-100 rounded-lg appearance-none cursor-pointer accent-primary-blue"
                />
            </div>

            <div class="space-y-2">
                <div
                    class="flex justify-between text-sm font-semibold text-gray-600"
                >
                    <label for="price-slider"
                        >Tariff Price (Elektrik Fiyatı)</label
                    >
                    <span id="price-value" class="text-primary-blue font-bold"
                        >₺ 3.2 / kWh</span
                    >
                </div>
                <input
                    type="range"
                    id="price-slider"
                    min="1.0"
                    max="6.0"
                    step="0.1"
                    value="3.2"
                    class="w-full h-2 bg-gray-100 rounded-lg appearance-none cursor-pointer accent-primary-blue"
                />
            </div>

            <div
                class="bg-gray-50 rounded-2xl p-5 border border-gray-100 space-y-3"
            >
                <p
                    class="text-xs font-bold text-gray-400 uppercase tracking-wider"
                >
                    Est. Additional Annual Revenue (Avg. 4% Gain)
                </p>
                <p
                    id="annual-savings"
                    class="text-3xl font-black text-accent-green"
                >
                    破 1,440,000
                </p>

                <div
                    class="grid grid-cols-2 gap-4 pt-3 border-t border-gray-200/60 text-xs"
                >
                    <div>
                        <p class="text-gray-400 font-medium">
                            10-Year Cumulative
                        </p>
                        <p
                            id="ten-year-savings"
                            class="font-bold text-dark text-sm mt-0.5"
                        >
                            ₺ 14,400,000
                        </p>
                    </div>
                    <div>
                        <p class="text-gray-400 font-medium">
                            CO₂ Reduction / Year
                        </p>
                        <p
                            id="co2-reduction"
                            class="font-bold text-dark text-sm mt-0.5"
                        >
                            9.0 ton
                        </p>
                    </div>
                </div>
            </div>

            <button
                class="w-full py-4 bg-primary-blue hover:bg-blue-700 text-white font-bold rounded-xl transition-colors shadow-lg shadow-blue-600/10"
            >
                Get Detailed Analysis Report
            </button>
        </div>
    </div>
</section>

<script>
    const powerSlider = document.getElementById(
        "power-slider",
    ) as HTMLInputElement;
    const productionSlider = document.getElementById(
        "production-slider",
    ) as HTMLInputElement;
    const priceSlider = document.getElementById(
        "price-slider",
    ) as HTMLInputElement;

    const powerValue = document.getElementById("power-value");
    const productionValue = document.getElementById("production-value");
    const priceValue = document.getElementById("price-value");

    const annualSavings = document.getElementById("annual-savings");
    const tenYearSavings = document.getElementById("ten-year-savings");
    const co2Reduction = document.getElementById("co2-reduction");

    function updateCalculator() {
        const power = parseInt(powerSlider.value);
        const production = parseInt(productionSlider.value) * 1000; // MWh to kWh
        const price = parseFloat(priceSlider.value);

        // Güncel değer yazıları
        if (powerValue)
            powerValue.textContent = `${power.toLocaleString("tr-TR")} MW`;
        if (productionValue)
            productionValue.textContent = `${(production / 1000).toLocaleString("tr-TR")} MWh`;
        if (priceValue) priceValue.textContent = `₺ ${price.toFixed(1)} / kWh`;

        // Hesaplamalar (Ortalama %4 verim artışı temel alınmıştır)
        const efficiencyIncrease = production * 0.04;
        const annualIncome = efficiencyIncrease * price;
        const tenYearIncome = annualIncome * 10;
        const co2Saved = (efficiencyIncrease * 0.5) / 1000;

        if (annualSavings)
            annualSavings.textContent = `₺ ${Math.round(annualIncome).toLocaleString("tr-TR")}`;
        if (tenYearSavings)
            tenYearSavings.textContent = `₺ ${Math.round(tenYearIncome).toLocaleString("tr-TR")}`;
        if (co2Reduction)
            co2Reduction.textContent = `${co2Saved.toFixed(1)} ton`;
    }

    powerSlider?.addEventListener("input", updateCalculator);
    productionSlider?.addEventListener("input", updateCalculator);
    priceSlider?.addEventListener("input", updateCalculator);

    // İlk açılışta tetikle
    updateCalculator();
</script>
