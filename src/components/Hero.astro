---
// Eğer ikonları Lucide gibi harici bir kütüphaneden çekmiyorsak, performansı korumak için
// tasarımdaki Sparkles ve ArrowRight ikonlarını saf SVG olarak buraya entegre ediyoruz.
---

<section
    class="relative min-h-[85vh] flex items-center overflow-hidden bg-gradient-to-br from-brand-dark via-slate-900 to-brand-dark py-24 md:py-32"
>
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div
            class="absolute top-20 left-10 w-72 h-72 bg-brand-teal/10 rounded-full blur-3xl animate-pulse"
        >
        </div>
        <div
            class="absolute bottom-20 right-10 w-96 h-96 bg-brand-green/10 rounded-full blur-3xl animate-pulse"
            style="animation-delay: 1s;"
        >
        </div>
        <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-teal/5 rounded-full blur-3xl"
        >
        </div>
    </div>

    <div
        class="absolute inset-0 opacity-5 pointer-events-none"
        style="background-image: linear-gradient(rgba(16, 185, 129, 0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(16, 185, 129, 0.1) 1px, transparent 1px); background-size: 50px 50px;"
    >
    </div>

    <div
        class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center"
    >
        <div
            class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 backdrop-blur-md border border-white/10 mb-8 shadow-xl"
        >
            <svg
                xmlns="http://www.w3.org/2000/ajax/libs/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand-teal"
                ><path
                    d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275Z"
                ></path><path d="m5 3 1 2.5L8.5 6 6 7 5 9.5 4 7 1.5 6 4 5.5Z"
                ></path><path
                    d="m19 17 1 2.5 2.5.5-2.5 1-1 2.5-1-2.5-2.5-1 2.5-1Z"
                ></path></svg
            >
            <span class="text-sm text-gray-200 font-medium tracking-wide"
                >Öncü Nano Kaplama Teknolojisi</span
            >
        </div>

        <h1
            class="mb-6 text-white max-w-5xl mx-auto text-4xl sm:text-6xl font-black tracking-tight leading-tight md:leading-none"
        >
            <span class="block mb-4">Teknolojiyi Şekillendiriyoruz</span>
            <span
                class="block text-transparent bg-clip-text bg-gradient-to-r from-white via-brand-teal to-brand-green"
            >
                Geleceğin Nano Kaplamaları
            </span>
        </h1>

        <p
            class="text-lg md:text-xl text-gray-300 max-w-3xl mx-auto mb-12 leading-relaxed font-normal"
        >
            Yüzeyleri hidrofobik, fotokatalitik ve koruyucu özelliklerle
            dönüştüren, 300nm kalınlığındaki devrimsel ince filmlerimizle güneş
            enerjisi verimliliğini en üst düzeye çıkarıyor ve sürdürülebilir bir
            gelecek sunuyoruz.
        </p>

        <div
            class="flex flex-col sm:flex-row gap-4 justify-center items-center"
        >
            <a
                href="/teknoloji"
                class="group px-8 py-4 bg-brand-teal hover:bg-brand-teal/90 text-brand-dark font-bold rounded-xl transition-all shadow-lg shadow-brand-teal/20 flex items-center gap-2"
            >
                Teknolojiyi Keşfet
                <svg
                    xmlns="http://www.w3.org/2000/ajax/libs/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="group-hover:translate-x-1 transition-transform"
                    ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                    ></path></svg
                >
            </a>
            <a
                href="/iletisim"
                class="px-8 py-4 bg-white/10 backdrop-blur-md border border-white/20 text-white font-semibold rounded-xl hover:bg-white/20 transition-all"
            >
                Bize Ulaşın
            </a>
        </div>
    </div>
</section>
