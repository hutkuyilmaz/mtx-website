---
interface Props {
	title: string;
}

const { title } = Astro.props;
import "../styles/global.css";
---

<!doctype html>
<html lang="tr" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="bg-light-gray text-dark font-sans antialiased">
		<nav
			class="fixed w-full z-50 bg-white/80 backdrop-blur-md border-b border-gray-100 shadow-sm"
		>
			<div
				class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between"
			>
				<div class="flex items-center gap-2">
					<div
						class="w-10 h-10 bg-primary-blue rounded-xl flex items-center justify-center text-white font-black text-xl shadow-md shadow-primary-blue/20"
					>
						M
					</div>
					<span
						class="text-2xl font-extrabold tracking-tight text-dark"
						>MATERIX<span class="text-accent-green">.</span></span
					>
				</div>
				<div
					class="hidden md:flex items-center gap-8 font-semibold text-sm"
				>
					<a href="#" class="text-primary-blue">Home</a>
					<a
						href="#about"
						class="text-gray-600 hover:text-primary-blue transition-colors"
						>Our Solution</a
					>
					<a
						href="#cases"
						class="text-gray-600 hover:text-primary-blue transition-colors"
						>Case Studies</a
					>
					<a
						href="#"
						class="text-gray-600 hover:text-primary-blue transition-colors"
						>Team</a
					>
					<a
						href="#"
						class="text-gray-600 hover:text-primary-blue transition-colors"
						>Partners</a
					>
					<a
						href="#calculator"
						class="text-gray-600 hover:text-primary-blue transition-colors"
						>Revenue Calculator</a
					>
					<a
						href="#"
						class="text-gray-600 hover:text-primary-blue transition-colors"
						>Contact</a
					>
					<a
						href="#"
						class="text-gray-600 hover:text-primary-blue transition-colors"
						>Blog</a
					>
					<span
						class="px-2 py-1 bg-gray-100 text-xs text-gray-600 rounded font-bold"
						>TW / EN</span
					>
				</div>
			</div>
		</nav>

		<div class="pt-20">
			<slot />
		</div>

		<footer
			class="bg-dark text-gray-400 py-12 border-t border-gray-800 text-center text-sm"
		>
			<div class="max-w-7xl mx-auto px-4">
				<p class="font-bold text-white mb-2">
					MATERIX Nano Teknoloji San. Tic. A.Ş.
				</p>
				<p>&copy; 2026 Materix Nano Teknoloji. Tüm Hakları Saklıdır.</p>
			</div>
		</footer>
	</body>
</html>
