---
// src/layouts/Layout.astro
interface Props {
	title: string;
}

const { title } = Astro.props;

// DIAGNOSTIC FIX: You must import your global styles here so Astro bundles them into the HTML head!
import "../styles/global.css";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="description"
			content="Materix Nano Teknoloji - Ultra-thin nano film protective solutions."
		/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-[#f6f6f5] antialiased">
		<slot />
	</body>
</html>
