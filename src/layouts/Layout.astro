---
interface Props {
	title: string;
}

const { title } = Astro.props;
import "../styles/global.css";
---

<!doctype html>
<html lang="tr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body
		class="bg-light-gray text-dark antialiased font-['Inter',_sans-serif]"
	>
		<nav
			class="fixed w-full z-50 bg-white/80 backdrop-blur-md border-b border-gray-100 shadow-sm"
		>
			<div
				class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between"
			>
				<div class="flex items-center gap-2">
					<div
						class="w-10 h-10 bg-blue-800 rounded-xl flex items-center justify-center text-white font-black text-xl shadow-md shadow-blue-800/20"
					>
						M
					</div>
					<span
						class="text-2xl font-extrabold tracking-tight text-slate-900"
						>MATERIX<span class="text-emerald-500">.</span></span
					>
				</div>
				<div
					class="hidden md:flex items-center gap-8 font-semibold text-sm text-slate-600"
				>
					<a href="#" class="text-blue-800 font-bold">Home</a>
					<a
						href="#about"
						class="hover:text-blue-800 transition-colors"
						>Our Solution</a
					>
					<a
						href="#cases"
						class="hover:text-blue-800 transition-colors"
						>Case Studies</a
					>
					<a href="#" class="hover:text-blue-800 transition-colors"
						>Team</a
					>
					<a href="#" class="hover:text-blue-800 transition-colors"
						>Partners</a
					>
					<a
						href="#calculator"
						class="hover:text-blue-800 transition-colors"
						>Revenue Calculator</a
					>
					<a href="#" class="hover:text-blue-800 transition-colors"
						>Contact</a
					>
					<a href="#" class="hover:text-blue-800 transition-colors"
						>Blog</a
					>
					<span
						class="px-2 py-1 bg-slate-100 text-xs text-slate-500 rounded font-bold"
						>TW / EN</span
					>
				</div>
			</div>
		</nav>

		<div class="pt-20">
			<slot />
		</div>

		<footer
			class="bg-slate-900 text-slate-400 py-12 mt-20 border-t border-slate-800 text-center text-sm"
		>
			<div class="max-w-7xl mx-auto px-4">
				<p class="font-bold text-white mb-2">
					MATERIX Nano Teknoloji San. Tic. A.Ş.
				</p>
				<p>&copy; 2026 Materix Nano Teknoloji. Tüm Hakları Saklıdır.</p>
			</div>
		</footer>
	</body>
</html>
